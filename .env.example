# OpenAI / Azure OpenAI
# These map to the GitHub Actions secret and variables of the same name.
OPENAI_API_KEY=sk-...

# LLM settings (GitHub Actions vars: LLM_MODEL, LLM_PROVIDER)
LLM_MODEL=gpt-4.1
LLM_PROVIDER=openai

# Azure OpenAI endpoint (GitHub Actions var: OPENAI_API_ENDPOINT)
# Leave blank to use the default openai.com API.
# Set to your Azure Cognitive Services endpoint to use Azure OpenAI, e.g.:
#   OPENAI_API_ENDPOINT=https://<resource>.cognitiveservices.azure.com/openai/v1/
OPENAI_API_ENDPOINT=

# Embedding model (GitHub Actions var: EMBEDDING_MODEL_SMALL)
EMBEDDING_MODEL_SMALL=text-embedding-3-small

# PostgreSQL / pgvector
#
# Option A (recommended for Docker Compose): set individual component vars.
# These match the standard Docker POSTGRES_* env vars used by the postgres
# container.  postgres_dsn is built automatically from these values.
# Replace passwords with strong secrets before going to production:
#   openssl rand -hex 32
# ---------------------------------------------------------------------------
POSTGRES_USER=tata
POSTGRES_PASSWORD=tata_password
POSTGRES_HOST=tata_postgres
POSTGRES_PORT=5432
POSTGRES_DB=tata_agent
#
# Option B: set POSTGRES_DSN directly (overrides the component vars above).
# ---------------------------------------------------------------------------
# POSTGRES_DSN=postgresql://tata:tata_password@tata_postgres:5432/tata_agent
#
PG_VECTOR_TABLE=tata_knowledge
PG_MEMORY_TABLE=tata_conversations
MEMORY_MAX_TURNS=10

# Chatwoot
CHATWOOT_BASE_URL=https://app.chatwoot.com
CHATWOOT_API_TOKEN=your-chatwoot-api-token
CHATWOOT_ACCOUNT_ID=1

# Webhook security token (optional -- leave blank to disable verification)
WEBHOOK_TOKEN=

# Logging
# Controls the verbosity of application log output.
# Accepted values (case-insensitive): debug, info, warning, error, critical
# Use "debug" to see full incoming payloads, every agent step, and Chatwoot HTTP responses.
LOG_LEVEL=info

# v03x Web Frontend
# CHATWOOT_MASTER_TOKEN — super-admin token for the Chatwoot API.
# Required to list accounts, inboxes, teams, and conversations from the web UI.
# Obtain it from Chatwoot → Super Admin → API Access Token.
CHATWOOT_MASTER_TOKEN=
