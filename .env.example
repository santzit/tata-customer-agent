# OpenAI / Azure OpenAI
# These map to the GitHub Actions secret and variables of the same name.
OPENAI_API_KEY=sk-...

# LLM settings (GitHub Actions vars: LLM_MODEL, LLM_PROVIDER)
LLM_MODEL=gpt-4.1
LLM_PROVIDER=openai

# Azure OpenAI endpoint (GitHub Actions var: OPENAI_API_ENDPOINT)
# Leave blank to use the default openai.com API.
# Set to your Azure Cognitive Services endpoint to use Azure OpenAI, e.g.:
#   OPENAI_API_ENDPOINT=https://<resource>.cognitiveservices.azure.com/openai/v1/
OPENAI_API_ENDPOINT=

# Embedding model (GitHub Actions var: EMBEDDING_MODEL_SMALL)
EMBEDDING_MODEL_SMALL=text-embedding-3-small

# PostgreSQL / pgvector
# Point this at the same Postgres that Chatwoot uses (pgvector extension required).
# Example for a local Chatwoot docker-compose setup:
#   POSTGRES_DSN=postgresql://postgres:password@chatwoot-postgres:5432/chatwoot
POSTGRES_DSN=postgresql://postgres:postgres@localhost:5432/tata_agent
PG_VECTOR_TABLE=tata_knowledge
PG_MEMORY_TABLE=tata_conversations
MEMORY_MAX_TURNS=10

# Chatwoot
CHATWOOT_BASE_URL=https://app.chatwoot.com
CHATWOOT_API_TOKEN=your-chatwoot-api-token
CHATWOOT_ACCOUNT_ID=1

# Chatwoot Help Center (HC) sync for RAG
# Set to the DSN of your Chatwoot database to enable syncing published Help
# Center articles into the RAG vector store at startup and via the CLI.
# This is the same Postgres host Chatwoot uses — just point at its database.
# Example: CHATWOOT_DSN=postgresql://chatwoot:password@localhost:5432/chatwoot_production
CHATWOOT_DSN=
# Set to false to disable automatic sync at startup (run manually instead):
HC_SYNC_ON_STARTUP=true

# Docs ingestion — populate the RAG store from a directory of .md files.
# Useful when you don't have Chatwoot Help Center or want a quick first load.
# Leave empty to disable (use python -m app.ingest_docs [dir] to run manually).
# Example: DOCS_DIR=/home/myapp/knowledge
DOCS_DIR=

# Webhook security token (optional -- leave blank to disable verification)
WEBHOOK_TOKEN=

# Logging
# Controls the verbosity of application log output.
# Accepted values (case-insensitive): debug, info, warning, error, critical
# Use "debug" to see full incoming payloads, every agent step, and Chatwoot HTTP responses.
LOG_LEVEL=info
